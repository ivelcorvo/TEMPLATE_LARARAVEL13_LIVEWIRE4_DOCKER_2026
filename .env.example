# ─────────────────────────────────────────
# APLICAÇÃO
# ─────────────────────────────────────────
APP_NAME="Minha Aplicação"
APP_SLUG=meu_projeto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# ─────────────────────────────────────────
# BANCO DE DADOS — PostgreSQL
# ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel_user
DB_PASSWORD=secret

# ─────────────────────────────────────────
# CACHE / SESSÃO / FILAS — Redis
# ─────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# MAIL (configurar conforme provedor)
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# LIVEWIRE
# ─────────────────────────────────────────
LIVEWIRE_TEMP_FILE_UPLOAD_DISK=local

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────
# SEGURANÇA
# ─────────────────────────────────────────
PASSWORD_RESET_TIMEOUT=60

# ─────────────────────────────────────────
# VITE (assets frontend)
# ─────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
